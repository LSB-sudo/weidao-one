<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BLE 串口调试"
        android:textSize="20sp"
        android:textColor="#a0c4ff"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● 未连接"
            android:textColor="#888888"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="扫描"
            android:textSize="13sp"
            android:backgroundTint="#1a5a3a"
            android:textColor="#66ffaa"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="断开"
            android:textSize="13sp"
            android:backgroundTint="#5a1a1a"
            android:textColor="#ffaaaa" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d0d1a"
        android:padding="8dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#cccccc"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etSend"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入指令，例如 FORWARD"
            android:textColor="#eeeeee"
            android:textColorHint="#555555"
            android:background="#2a2a4a"
            android:padding="10dp"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            android:inputType="text"
            android:imeOptions="actionSend" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送"
            android:backgroundTint="#2a4a2a"
            android:textColor="#88ff88" />
    </LinearLayout>
</LinearLayout>
