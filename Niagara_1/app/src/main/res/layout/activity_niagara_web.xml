<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111827">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:background="#0f172a">

        <ImageButton
            android:id="@+id/btnNiagaraBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#1e293b"
            android:contentDescription="@string/niagara_back"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#e2e8f0" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/niagara_title"
                android:textColor="#f8fafc"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNiagaraUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#93c5fd"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnNiagaraRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#1e293b"
            android:contentDescription="@string/niagara_refresh"
            android:padding="10dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#e2e8f0" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressNiagara"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#38bdf8" />

    <TextView
        android:id="@+id/tvNiagaraError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="#3f1d1d"
        android:padding="12dp"
        android:textColor="#fecaca"
        android:textSize="13sp"
        android:visibility="gone" />

    <WebView
        android:id="@+id/webNiagara"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
